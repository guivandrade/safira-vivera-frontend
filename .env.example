# API
NEXT_PUBLIC_API_URL=http://localhost:3000

# Observability — Sentry (opcional)
# Deixe em branco para desativar (SDK fica no-op)
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENV=production

# Source-map upload em CI (opcional)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Feature flags (optional)
# NEXT_PUBLIC_ANALYTICS=true

# Dev autofill (apenas dev local — preenche login com 1 clique)
# Renderiza botão "Preencher credenciais de dev" só quando NODE_ENV=development
# NEXT_PUBLIC_DEV_LOGIN_EMAIL=
# NEXT_PUBLIC_DEV_LOGIN_PASSWORD=
